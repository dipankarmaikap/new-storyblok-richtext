---
import type { PMNode, StoryblokRichTextComponentMap } from "../";
import RichTextMark from "./RichTextMark.astro";

interface Props {
  node: PMNode;
  components?: StoryblokRichTextComponentMap;
}

const { node, components } = Astro.props;

if (node.type !== "text") {
  return null;
}

const reversedMarks = [...(node.marks ?? [])];
---

{
  reversedMarks.reduce(
    (acc, mark) => (
      <RichTextMark mark={mark} components={components}>
        {acc}
      </RichTextMark>
    ),
    <Fragment>{node.text}</Fragment>,
  )
}
