---
import type { StoryblokComponnetMap, StoryblokRichTextJson } from '..';
import { resolveMarkTag, transformAttrs } from '../utils';

interface Props {
  node?: StoryblokRichTextJson;
  components?: StoryblokComponnetMap<any>;
}
const { node, components } = Astro.props;
const marks = node?.marks ?? [];
---

{
  marks.length > 0 ? (
    (() => {
      let content: any = node?.text ?? '';
      // wrap marks inside-out
      for (let i = marks.length - 1; i >= 0; i--) {
        const mark = marks[i];
        const Tag = components?.[mark.type] ?? resolveMarkTag(mark);
        content = <Tag {...transformAttrs(mark.attrs)}>{content}</Tag>;
      }
      return content;
    })()
  ) : (
    <>{node?.text}</>
  )
}
