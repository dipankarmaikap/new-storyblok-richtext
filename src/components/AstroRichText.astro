---
import AstroRichTextRenderer from "@/lib/richtext-renderer/astro/AstroRichTextRenderer.astro";
import type { StoryblokRichTextJson } from "@/lib/richtext-renderer";
import CustomHeading from "@/components/astro/CustomHeading.astro";
import BlokResolver from "@/components/astro/BlokResolver.astro";

interface Props {
  doc: StoryblokRichTextJson;
}
const { doc } = Astro.props;
---

<section class="astro">
  <h2 class="text-2xl font-bold mb-4 text-purple-600">
    Astro Renderer Output (with Custom Components)
  </h2>
  <div
    class="p-6 bg-white rounded-lg shadow-md border border-gray-200 max-w-none"
  >
    <AstroRichTextRenderer
      doc={doc}
      components={{
        heading: CustomHeading,
        blok: BlokResolver,
      }}
    />
  </div>
</section>
