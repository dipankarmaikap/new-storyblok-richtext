---
import {
  resolveComponent,
  type PMNode,
  type StoryblokRichTextComponentMap,
} from "..";
import TextRenderer from "./TextRenderer.astro";
import StandardNodeRenderer from "./StandardNodeRenderer.astro";

interface Props {
  node: PMNode;
  components?: StoryblokRichTextComponentMap;
}

const { node, components } = Astro.props;

const NodeComponent = resolveComponent(node.type, components);
---

{
  node.type === "text" ? (
    <TextRenderer node={node} components={components} />
  ) : NodeComponent ? (
    <NodeComponent {...node} components={components} />
  ) : (
    <StandardNodeRenderer node={node} components={components} />
  )
}
