---
import type { RichTextComponentProps } from '../lib/richtext-renderer/astro/types';

// We explicitly declare the Exact string Tiptap name our Custom Node expects
export interface Props extends RichTextComponentProps<'heading'> {}

const { attrs } = Astro.props;

const Tag = `h${attrs.level ?? 2}`;
const className = `text-orange-600 border-b-2 border-orange-200 pb-2 mb-4 mt-8 level-${attrs.level}`;
---

<Tag class={className}>
  <slot />
</Tag>
