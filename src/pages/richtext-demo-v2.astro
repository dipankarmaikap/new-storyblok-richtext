---
import BaseLayout from '../layouts/BaseLayout.astro';
import { sampleDoc } from '../data/sampleDoc';
import AstroRichTextRenderer from '../lib/richtext-renderer/astro/AstroRichTextRenderer.astro';
import { richTextResolver } from '@storyblok/richtext';
import CustomHeading from '../components/CustomHeading.astro';
import BlokResolver from '../components/BlokResolver.astro';
const { render } = richTextResolver();
const html = render(sampleDoc);
---

<BaseLayout>
  <div class="bg-gray-50 min-h-screen p-8 text-gray-900">
    <div class="space-y-12 flex gap-6">
      {/* Astro Adapter Output */}
      <section>
        <h2 class="text-2xl font-bold mb-4 text-orange-600">Astro Native Renderer Output (with Custom Components)</h2>
        <div class="p-6 bg-white rounded-lg shadow-md border border-gray-200 prose prose-orange max-w-none">
          <AstroRichTextRenderer
            doc={sampleDoc}
            components={{
              heading: CustomHeading,
              blok: BlokResolver,
            }}
          />
        </div>
      </section>
      <section>
        <h2 class="text-2xl font-bold mb-4 text-orange-600">
          Existing Richtext Renderer Output (without Custom Components)
        </h2>
        <div class="p-6 bg-white rounded-lg shadow-md border border-gray-200 prose prose-orange max-w-none">
          <div set:html={html} />
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
