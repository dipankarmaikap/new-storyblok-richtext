---
import BaseLayout from "../layouts/BaseLayout.astro";
import { sampleDoc } from "../data/sampleDoc";
import { richTextResolver } from "@storyblok/richtext";
import type { StoryblokRichTextJson } from "@/lib/richtext-renderer";
import ReactRichText from "@/components/ReactRichText";
import AstroRichText from "@/components/AstroRichText.astro";
// import SvelteRichText from "@/components/SvelteRichText.svelte";
import VueRichText from "@/components/VueRichText.vue";
const { render } = richTextResolver();
const html = render(sampleDoc as any);
---

<BaseLayout>
  <div class="bg-gray-50 min-h-screen p-8 text-gray-900">
    <div class="flex gap-6 overflow-scroll flex-nowrap">
      <AstroRichText doc={sampleDoc as StoryblokRichTextJson} />
      <ReactRichText doc={sampleDoc as StoryblokRichTextJson} />
      <!-- <SvelteRichText doc={sampleDoc as StoryblokRichTextJson} /> -->
      <VueRichText doc={sampleDoc as StoryblokRichTextJson} />

      <!-- <section>
        <h2 class="text-2xl font-bold mb-4 text-gray-600">
          Existing Richtext Renderer Output
        </h2>
        <div
          class="p-6 bg-white rounded-lg shadow-md border border-gray-200 max-w-none"
        >
          <div set:html={html} />
        </div>
      </section> -->
    </div>
  </div>
</BaseLayout>
